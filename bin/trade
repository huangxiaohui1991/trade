#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

cd "$REPO_ROOT"

# 使用仓库内统一虚拟环境（由 pyenv 3.12.13 创建）
PYTHON="$REPO_ROOT/.venv/bin/python"

if [ ! -f "$PYTHON" ]; then
    echo "错误：未找到项目虚拟环境 ($PYTHON)" >&2
    echo "请运行：pyenv exec python -m venv .venv && .venv/bin/pip install -r requirements.txt" >&2
    exit 1
fi

exec "$PYTHON" -m scripts.cli.trade "$@"
