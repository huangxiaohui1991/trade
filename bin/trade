#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

cd "$REPO_ROOT"

# 使用 Python 3.12 虚拟环境
PYTHON="$REPO_ROOT/venv312/bin/python3.12"

if [ ! -f "$PYTHON" ]; then
    echo "错误：未找到 Python 3.12 虚拟环境 ($PYTHON)" >&2
    echo "请运行：brew install python@3.12 && python3.12 -m venv venv312 && source venv312/bin/activate && pip install akshare pandas rich prompt-toolkit openai" >&2
    exit 1
fi

exec "$PYTHON" -m scripts.cli.trade "$@"
