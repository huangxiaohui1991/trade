# A股交易系统 · Hermes 原生架构 crontab
#
# 与 ARCHITECTURE.md §五 对齐：
#   08:25 盘前摘要 | 11:55 午休检查 | 15:35 收盘报告 | 15:40 核心池评分 | 周日20:00 周报
#
# 安装方式：
#   方式A（Hermes 自带调度）: 在 Hermes 配置中添加以下条目
#   方式B（macOS crontab）:
#     crontab -e
#     # 粘贴以下内容（调整 HERMES_SCRIPT 路径）
#
# 注意：所有路径使用绝对路径

HERMES_SCRIPT="/Users/hxh/Documents/a-stock-trading/scripts/hermes_cron.sh"
LOG_DIR="/Users/hxh/Documents/a-stock-trading/data"
PYTHON_HOME="/Users/hxh/.venv/akshare"

# 盘前摘要 — 周一到周五 8:25
25 8 * * 1-5 cd /Users/hxh/Documents/a-stock-trading && HERMES_SCRIPT="/Users/hxh/Documents/a-stock-trading/scripts/hermes_cron.sh" AStockVault="/Users/hxh/Documents/a-stock-trading" /bin/bash $HERMES_SCRIPT morning >> $LOG_DIR/cron_morning.log 2>&1

# 午休检查 — 周一到周五 11:55
55 11 * * 1-5 cd /Users/hxh/Documents/a-stock-trading && HERMES_SCRIPT="/Users/hxh/Documents/a-stock-trading/scripts/hermes_cron.sh" AStockVault="/Users/hxh/Documents/a-stock-trading" /bin/bash $HERMES_SCRIPT noon >> $LOG_DIR/cron_noon.log 2>&1

# 收盘报告 — 周一到周五 15:35
35 15 * * 1-5 cd /Users/hxh/Documents/a-stock-trading && HERMES_SCRIPT="/Users/hxh/Documents/a-stock-trading/scripts/hermes_cron.sh" AStockVault="/Users/hxh/Documents/a-stock-trading" /bin/bash $HERMES_SCRIPT evening >> $LOG_DIR/cron_evening.log 2>&1

# 核心池评分 — 周一到周五 15:40
40 15 * * 1-5 cd /Users/hxh/Documents/a-stock-trading && HERMES_SCRIPT="/Users/hxh/Documents/a-stock-trading/scripts/hermes_cron.sh" AStockVault="/Users/hxh/Documents/a-stock-trading" /bin/bash $HERMES_SCRIPT scoring >> $LOG_DIR/cron_scoring.log 2>&1

# 周报 — 周日 20:00
0 20 * * 0 cd /Users/hxh/Documents/a-stock-trading && HERMES_SCRIPT="/Users/hxh/Documents/a-stock-trading/scripts/hermes_cron.sh" AStockVault="/Users/hxh/Documents/a-stock-trading" /bin/bash $HERMES_SCRIPT weekly >> $LOG_DIR/cron_weekly.log 2>&1
